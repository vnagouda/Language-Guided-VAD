# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.env/
.venv/

# IDE / Editor settings
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# ---------------------------------------------------------------
# DATA — too large for git (several GB)
# ---------------------------------------------------------------
# Raw UCF-Crime PNG frames (100s of GB)
data/raw/

# Pre-extracted .pt feature tensors (several GB)
data/features/

# Video files
*.mp4
*.avi
*.mkv

# PyTorch model weights / checkpoints  (large binary files)
# NOTE: keep best_model.pth in checkpoints/ so professor can load the trained model
# *.pth  <-- intentionally NOT ignored so checkpoints/ is pushed
*.ckpt
*.bin

# ---------------------------------------------------------------
# RESULTS — these SHOULD be pushed (small .npy files)
# results/ is deliberately NOT ignored
# ---------------------------------------------------------------

# Logs and run tracking
logs/
runs/
wandb/
*.log

# Distribution / packaging
dist/
build/
*.egg-info/

# Environment variables (secrets)
.env
.env.local
